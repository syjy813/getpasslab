---
import BaseLayout from './BaseLayout.astro';
import { SUBJECTS, type SubjectId } from '../config/subjects';
import { withBase } from '../config/url';
interface SideCh { slug: string; title: string; group: string; }
interface Props {
  title: string; summary: string; subject_id: number; group: string; tags: string[];
  sideChapters: SideCh[];
}
const { title, summary, subject_id, group, tags, sideChapters } = Astro.props;
const subject = SUBJECTS[subject_id as SubjectId];
const subjectUrl = withBase(`/industrial-safety/written/${subject.slug}/`);
const groups = [...new Set(sideChapters.map(c => c.group))];
---
<BaseLayout title={`${title} | 산업안전기사 핵심요약 - GetPassLab`} description={summary}>
  <div class="chapter-wrap">
    <aside class="chapter-side">
      <div class="side-sticky">
        <div class="gpl-caption" style="margin-bottom:var(--space-2)">{subject_id}과목 · 챕터 목록</div>
        <nav class="side-nav">
          {groups.map(g => (
            <>
              <div class="side-group">{g}</div>
              {sideChapters.filter(c => c.group === g).map(c => (
                <a href={withBase(`/industrial-safety/written/${subject.slug}/${c.slug}/`)} class={c.title === title ? 'active' : ''}>{c.title}</a>
              ))}
            </>
          ))}
        </nav>
      </div>
    </aside>
    <main style="min-width:0">
      <nav class="breadcrumb">
        <a href={withBase('/')}>홈</a><span class="sep">/</span>
        <a href={withBase('/industrial-safety/')}>산업안전기사</a><span class="sep">/</span>
        <a href={withBase('/industrial-safety/written/')}>필기</a><span class="sep">/</span>
        <a href={subjectUrl}>{subject_id}과목</a><span class="sep">/</span>
        <span class="current">{title}</span>
      </nav>
      <div style="display:flex;gap:var(--space-2);margin:var(--space-4) 0 var(--space-2)">
        {tags.map(t => <span class={`tag${t === '빈출' ? ' hot' : ''}`}>#{t}</span>)}
      </div>
      <h1 class="gpl-display">{title}</h1>
      <p class="gpl-body-lg" style="color:var(--gray-600);margin:var(--space-2) 0 var(--space-6)">{summary}</p>
      <article><slot /></article>
    </main>
  </div>
</BaseLayout>
