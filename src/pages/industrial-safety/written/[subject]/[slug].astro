---
import { getCollection, render } from 'astro:content';
import ChapterLayout from '../../../../layouts/ChapterLayout.astro';
import QuestionHistory from '../../../../components/QuestionHistory.astro';
import RelatedChapters from '../../../../components/RelatedChapters.astro';
import { SUBJECTS, type SubjectId } from '../../../../config/subjects';

export async function getStaticPaths() {
  // 공개 대상: 작성 완료 챕터만. 미시작 스텁은 페이지 생성 안 함(빈 본문 비공개).
  const chapters = (await getCollection('chapters')).filter(c => c.data.status === '완료');
  return chapters.map(ch => ({
    params: {
      subject: SUBJECTS[ch.data.subject_id as SubjectId].slug,
      slug: ch.data.slug,
    },
    props: { chapter: ch },
  }));
}

const { chapter } = Astro.props;
const { Content } = await render(chapter);

const allQuestions = await getCollection('questions');
const questionsById = new Map(allQuestions.map((question) => [question.data.id, question.data]));
const seenQuestionIds = new Set<string>();
const linked = [];

for (const questionId of chapter.data.questions ?? []) {
  if (seenQuestionIds.has(questionId)) continue;
  seenQuestionIds.add(questionId);

  const question = questionsById.get(questionId);
  if (!question) {
    console.warn(
      `[public-question-filter] chapter=${chapter.data.slug} question_id=${questionId} excluded: missing from questions.json`,
    );
    continue;
  }

  const exclusionReasons: string[] = [];
  if (question.review === 'jpg 확필') exclusionReasons.push('review=jpg 확필');
  if (!Array.isArray(question.choices) || question.choices.length !== 4) {
    exclusionReasons.push(
      `choices length is ${Array.isArray(question.choices) ? question.choices.length : 'not-an-array'}`,
    );
  } else if (question.choices.some((choice) => typeof choice !== 'string' || choice.trim() === '')) {
    exclusionReasons.push('blank choice');
  }

  if (exclusionReasons.length > 0) {
    console.warn(
      `[public-question-filter] chapter=${chapter.data.slug} question_id=${questionId} excluded: ${exclusionReasons.join('; ')}`,
    );
    continue;
  }

  linked.push(question);
}

const allChapters = (await getCollection('chapters')).filter(c => c.data.status === '완료');
const manual = chapter.data.related
  .map(s => allChapters.find(c => c.data.slug === s)?.data)
  .filter(Boolean);
const sameGroup = allChapters
  .filter(c => c.data.group === chapter.data.group && c.data.slug !== chapter.data.slug)
  .map(c => c.data);
const sideChapters = allChapters
  .filter(c => c.data.subject_id === chapter.data.subject_id)
  .map(c => ({ slug: c.data.slug, title: c.data.title, group: c.data.group }));
---
<ChapterLayout {...chapter.data} sideChapters={sideChapters}>
  <Content />
  <QuestionHistory questions={linked as any} examComment={chapter.data.examComment} />
  <RelatedChapters manual={manual as any} sameGroup={sameGroup as any} />
</ChapterLayout>
